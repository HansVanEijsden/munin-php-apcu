#!/bin/bash
# Munin plugin voor PHP APCu stats - per container
# Versie: 1.0.3 - Geen warnings (APCu managed cache)

PLUGIN_NAME="${0##*/}"
CONTAINER="${PLUGIN_NAME#php_apcu_}"
CONTAINER="${CONTAINER//_/-}"
SOCKET="/run/php/${CONTAINER}.sock"
SAFE_NAME="${CONTAINER//-/_}"

get_apcu_stats() {
    SCRIPT_NAME=/tmp/apcu-status.php \
    SCRIPT_FILENAME=/tmp/apcu-status.php \
    REQUEST_METHOD=GET \
    cgi-fcgi -bind -connect "$SOCKET" 2>&1 | tail -1
}

do_memory_config() {
    cat <<EOF
graph_title PHP APCu memory usage - ${CONTAINER}
graph_args --base 1024 -l 0
graph_vlabel bytes
graph_category php-apcu
graph_info APCu memory usage for ${CONTAINER}. APCu manages its own cache and will evict old entries when needed.
graph_order used free total

used.label Used memory
used.type GAUGE
used.min 0
used.draw AREA
used.colour 44AD4E
used.info Currently used APCu memory (seg_size - avail_mem)

free.label Free memory
free.type GAUGE
free.min 0
free.draw STACK
free.colour 6BAED6
free.info Available APCu memory (no warnings - APCu manages cache automatically)

total.label Total memory
total.type GAUGE
total.min 0
total.draw LINE2
total.colour 999999
total.info Total APCu memory available (seg_size)
EOF
}

do_values() {
    local json=$(get_apcu_stats)
    
    # Parse JSON met jq (als beschikbaar)
    if command -v jq >/dev/null 2>&1; then
        local total=$(echo "$json" | jq -r '.seg_size // 0')
        local free=$(echo "$json" | jq -r '.avail_mem // 0')
        local used=$((total - free))
        
        echo "used.value $used"
        echo "free.value $free"
        echo "total.value $total"
    else
        # Fallback naar grep/sed als jq niet beschikbaar is
        local total=$(echo "$json" | grep -o '"seg_size":[0-9]*' | cut -d':' -f2)
        local free=$(echo "$json" | grep -o '"avail_mem":[0-9]*' | cut -d':' -f2)
        
        if [ -z "$total" ]; then
            total=0
        fi
        if [ -z "$free" ]; then
            free=0
        fi
        local used=$((total - free))
        
        echo "used.value $used"
        echo "free.value $free"
        echo "total.value $total"
    fi
}

# Main logic
if ! docker ps --format "{{.Names}}" | grep -qx "$CONTAINER"; then
    echo "Container $CONTAINER not found" >&2
    exit 1
fi

if [ ! -S "$SOCKET" ]; then
    echo "Socket $SOCKET not found" >&2
    exit 1
fi

case "$1" in
    config)
        echo "multigraph php_apcu_memory_${SAFE_NAME}"
        do_memory_config
        ;;
    *)
        echo "multigraph php_apcu_memory_${SAFE_NAME}"
        do_values
        ;;
esac