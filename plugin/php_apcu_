#!/bin/bash
# Munin plugin voor PHP APCu stats - per container
# Versie: 1.0.0

PLUGIN_NAME="${0##*/}"
CONTAINER="${PLUGIN_NAME#php_apcu_}"
CONTAINER="${CONTAINER//_/-}"  # Zet underscores terug naar streepjes
SOCKET="/run/php/${CONTAINER}.sock"

# Veilige naam voor Munin (streepjes -> underscores)
SAFE_NAME="${CONTAINER//-/_}"

get_apcu_stats() {
    SCRIPT_NAME=/tmp/apcu-status.php \
    SCRIPT_FILENAME=/tmp/apcu-status.php \
    REQUEST_METHOD=GET \
    cgi-fcgi -bind -connect "$SOCKET" 2>&1 | tail -1
}

do_memory_config() {
    cat <<EOF
graph_title PHP APCu memory usage - ${CONTAINER}
graph_args --base 1024 -l 0
graph_vlabel bytes
graph_category php-apcu
graph_info APCu memory usage for ${CONTAINER}. Shows when memory is nearly full (free memory near 0).
graph_order used free total

used.label Used memory
used.type GAUGE
used.min 0
used.draw AREA
used.colour 44AD4E
used.info Currently used APCu memory (seg_size - avail_mem)

free.label Free memory
free.type GAUGE
free.min 0
free.draw STACK
free.colour 6BAED6
free.warning 10485760:
free.critical 5242880:
free.info Available APCu memory (warning if below 10MB, critical if below 5MB)

total.label Total memory
total.type GAUGE
total.min 0
total.draw LINE2
total.colour 999999
total.info Total APCu memory available (seg_size)
EOF
}

do_values() {
    local json=$(get_apcu_stats)
    
    echo "$json" | php -r '
        $data = json_decode(file_get_contents("php://stdin"), true);
        if (!$data || !isset($data["seg_size"])) {
            echo "used.value U\nfree.value U\ntotal.value U\n";
            exit(1);
        }
        
        $total = $data["seg_size"];
        $free = $data["avail_mem"];
        $used = $total - $free;
        
        echo "used.value " . $used . "\n";
        echo "free.value " . $free . "\n";
        echo "total.value " . $total . "\n";
    '
}

# Main logic
if ! docker ps --format "{{.Names}}" | grep -qx "$CONTAINER"; then
    echo "Container $CONTAINER not found" >&2
    exit 1
fi

if [ ! -S "$SOCKET" ]; then
    echo "Socket $SOCKET not found" >&2
    exit 1
fi

case "$1" in
    config)
        echo "multigraph php_apcu_memory_${SAFE_NAME}"
        do_memory_config
        ;;
    *)
        echo "multigraph php_apcu_memory_${SAFE_NAME}"
        do_values
        ;;
esac